# Required: Postgres connection string (from the database container env or connection details)
POSTGRES_URL=postgresql://appuser:dbuser123@localhost:5000/myapp

# Required: JWT signing secret (set to a long random value in production)
JWT_SECRET_KEY=change-me-to-a-long-random-string

# Optional
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Comma-separated list of allowed frontend origins (set to deployed Next.js URL)
CORS_ALLOW_ORIGINS=http://localhost:3000
ENVIRONMENT=development
